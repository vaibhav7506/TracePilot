# TracePilot QA — environment configuration
# Copy this file to `.env` and fill in real values:  cp .env.example .env

# --- Database ---------------------------------------------------------------
# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tracepilot?schema=public"

# --- AI provider (OpenAI-compatible) ----------------------------------------
# Any provider exposing an OpenAI-compatible API (OpenAI, Azure OpenAI,
# OpenRouter, a local server, etc.). Used by the planning layer in a later phase.
AI_PROVIDER="openai"
AI_API_KEY="sk-your-key-here"
AI_BASE_URL="https://api.openai.com/v1"

# --- App --------------------------------------------------------------------
# Public origin of this app. Used for absolute URLs and metadata.
APP_URL="http://localhost:3000"
