DATABASE_URL=
AUTH_SECRET=
APP_ENCRYPTION_KEY=
APP_URL=

AI_PROVIDER=groq
AI_MODEL=
AI_API_KEY=
AI_BASE_URL=
# User BYOK is always preferred. Set true only if user failures may use the platform account.
ALLOW_PLATFORM_AI_FALLBACK=false

OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=

GROQ_API_KEY=
GROQ_MODEL=
GROQ_BASE_URL=https://api.groq.com/openai/v1

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

GEMINI_API_KEY=
GEMINI_MODEL=

# Runner policy (global, environment-managed)
RUNNER_MAX_STEPS=14
RUNNER_MAX_RUNTIME_MS=90000
RUNNER_NAVIGATION_TIMEOUT_MS=20000
RUNNER_CAPTURE_SCREENSHOTS=true
RUNNER_CAPTURE_CONSOLE=true
RUNNER_CAPTURE_NETWORK=true
RUNNER_SAME_DOMAIN_ONLY=true
RUNNER_DESTRUCTIVE_PROTECTION=true
# Honored only when NODE_ENV=development. Keep false unless local targets are intentional.
RUNNER_ALLOW_PRIVATE_NETWORK=false
# Chromium sandboxing stays enabled by default. Use only in a hardened container that requires it.
PLAYWRIGHT_DISABLE_SANDBOX=false

# Playwright generation policy
TEST_INCLUDE_SMOKE=true
TEST_INCLUDE_NAVIGATION=true
TEST_INCLUDE_FORMS=true
TEST_INCLUDE_REGRESSIONS=true
